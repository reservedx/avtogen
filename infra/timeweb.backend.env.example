APP_ENV=production
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
REDIS_URL=redis://HOST:6379/0
ASSET_STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://s3.timeweb.cloud
S3_ACCESS_KEY=changeme
S3_SECRET_KEY=changeme
S3_BUCKET=avtogen-assets
S3_REGION=ru-1
S3_PUBLIC_BASE_URL=
ASSET_STORAGE_DIR=/app/data/generated_assets
OPENAI_API_KEY=changeme
OPENAI_BRIEF_MODEL=gpt-5.4-mini
OPENAI_DRAFT_MODEL=gpt-5.4
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_OUTPUT_FORMAT=webp
YOUTUBE_API_KEY=changeme
YOUTUBE_MAX_RESULTS=5
YOUTUBE_TRANSCRIPT_LANGUAGES=en,ru
WORDPRESS_BASE_URL=https://example.com
WORDPRESS_USERNAME=editor
WORDPRESS_APP_PASSWORD=changeme
AUTO_PUBLISH_ENABLED=false
FAST_PUBLISH_ENABLED=true
AUTO_APPROVE_LOW_RISK=true
AUTO_PUBLISH_LOW_RISK=false
MIN_QUALITY_SCORE=78
MAX_RISK_SCORE_FOR_AUTO_PUBLISH=20
FAST_LANE_MIN_QUALITY_SCORE=68
FAST_LANE_MAX_RISK_SCORE=12
REQUIRED_SOURCE_COUNT=2
SIMILARITY_THRESHOLD=0.86
USE_STUB_GENERATION=true
AUTH_ENABLED=true
AUTH_ADMIN_TOKEN=change-admin-token
AUTH_EDITOR_TOKEN=change-editor-token
AUTH_OPERATOR_TOKEN=change-operator-token
DEFAULT_MEDICAL_DISCLAIMER=Важно: Информация в статье не заменяет консультацию специалиста. Обратитесь к врачу при любых тревожных симптомах.
